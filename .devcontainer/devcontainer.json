// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/debian
{
	"name": "Debian",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"build": {
		"dockerfile": "Dockerfile",
		"context": "."
	},
	"features": {
		"ghcr.io/devcontainers-extra/features/opentofu:1": {},
		// "ghcr.io/devcontainers/features/python:1": {},
		"ghcr.io/devcontainers/features/docker-in-docker:3": {},
		"ghcr.io/devcontainers/features/github-cli:1": {},
		"ghcr.io/devcontainers/features/go:1": {}
	},
	"runArgs": [
		"--add-host=host.docker.internal:host-gateway"
	],
	"mounts": [
		"source=homelab-ops-incus-config,target=/home/vscode/.config/incus,type=volume"
	],
	"initializeCommand": ".devcontainer/host-setup/setup-incus-trust.sh",
	"customizations": {
		"vscode": {
			"extensions": [
				"anthropic.claude-code",
				"GitHub.vscode-pull-request-github",
				"GitHub.vscode-github-actions",
				"golang.go"
			]
		}
	},

	"postStartCommand": "TEMPDIR=$(mktemp -d) && cp -r .devcontainer/scripts/* $TEMPDIR/ && chmod +x $TEMPDIR/*.sh && for f in $TEMPDIR/*.sh; do $f; done && rm -rf $TEMPDIR",

	// Features to add to the dev container. More info: https://containers.dev/features.
	// "features": {},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// "forwardPorts": [],

	// Configure tool-specific properties.
	// "customizations": {},

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
